---
import markUrl from "../assets/tool-mark.svg?url";
import { siteConfig } from "../site.config.mjs";
import "../styles/theme.css";
import "../styles/landing.css";

const siteBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const sitePath = (path: string = "") => `${siteBase}${path.replace(/^\/+/, "")}`;
const isExternal = (href: string) => /^https?:\/\//.test(href);
const resolveHref = (href: string) =>
  isExternal(href) || href.startsWith("#") ? href : sitePath(href);
const externalRel = (href: string) => (isExternal(href) ? "noopener noreferrer" : undefined);
const externalTarget = (href: string) => (isExternal(href) ? "_blank" : undefined);
const docsHref = siteConfig.docs.pages[0]?.href || "docs/";
const harborBackdrop = sitePath("assets/harbor-backdrop.png");
---

<!doctype html>
<html lang={siteConfig.site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteConfig.project.title} | {siteConfig.project.tagline}</title>
    <meta name="description" content={siteConfig.project.description} />
    <meta property="og:title" content={siteConfig.project.title} />
    <meta property="og:description" content={siteConfig.project.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteConfig.site.url} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href={sitePath("favicon.svg")} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&family=Source+Sans+3:wght@400;500;600;700&display=swap"
    />
  </head>
  <body class="landing-page" style={`--harbor-backdrop: url("${harborBackdrop}")`}>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header" data-site-header>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="site-nav__brand" href={sitePath()} aria-label={`${siteConfig.project.title} home`}>
          <img src={markUrl} alt="" width="36" height="36" />
          <span>{siteConfig.project.title}</span>
        </a>

        <div class="site-nav__links">
          {siteConfig.landing.nav.map((link) => (
            <a
              class="site-nav__link"
              href={resolveHref(link.href)}
              target={externalTarget(link.href)}
              rel={externalRel(link.href)}
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="site-nav__actions">
          <a class="button button--ghost button--sm" href={resolveHref(docsHref)}>Docs</a>
          <button
            class="site-nav__toggle"
            type="button"
            aria-label="Open navigation"
            aria-controls="mobile-nav"
            aria-expanded="false"
            data-nav-toggle
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16"></path>
            </svg>
          </button>
        </div>
      </nav>

      <div class="mobile-nav" id="mobile-nav" data-nav-panel hidden>
        {siteConfig.landing.nav.map((link) => (
          <a
            class="mobile-nav__link"
            href={resolveHref(link.href)}
            target={externalTarget(link.href)}
            rel={externalRel(link.href)}
            data-nav-link
          >
            {link.label}
          </a>
        ))}
      </div>
    </header>

    <main id="main">
      <section class="hero section-shell" aria-labelledby="hero-title">
        <div class="hero__copy">
          <p class="eyebrow">{siteConfig.project.category}</p>
          <div class="hero__brand-line">
            <img src={markUrl} alt="" width="64" height="64" />
            <h1 id="hero-title">{siteConfig.project.title}</h1>
          </div>
          <p class="hero__lede">{siteConfig.project.tagline}</p>
          <p class="hero__body">{siteConfig.project.description}</p>

          <div class="badge-row" aria-label="Project highlights">
            {siteConfig.landing.badges.map((badge) => <span class="badge">{badge}</span>)}
          </div>

          <div class="hero__actions">
            <a class="button button--primary" href={resolveHref(siteConfig.landing.primaryCta.href)}>
              {siteConfig.landing.primaryCta.label}
              <svg class="button__icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"></path>
              </svg>
            </a>
            <a
              class="button button--secondary"
              href={resolveHref(siteConfig.landing.secondaryCta.href)}
              target={externalTarget(siteConfig.landing.secondaryCta.href)}
              rel={externalRel(siteConfig.landing.secondaryCta.href)}
            >
              {siteConfig.landing.secondaryCta.label}
            </a>
          </div>
        </div>

        <div class="command-card" aria-labelledby="command-card-title">
          <div class="command-card__header">
            <div>
              <p class="eyebrow">Terminal</p>
              <h2 id="command-card-title">{siteConfig.landing.terminal.title}</h2>
            </div>
            <span>{siteConfig.landing.terminal.meta}</span>
          </div>
          <pre class="command-card__body"><code>{siteConfig.landing.terminal.lines.join("\n")}</code></pre>
          <button
            class="copy-button"
            type="button"
            data-copy-text={siteConfig.landing.terminal.copy}
            aria-label={`Copy command: ${siteConfig.landing.terminal.copy}`}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="8" y="8" width="11" height="12" rx="2"></rect>
              <path d="M5 15V6a2 2 0 0 1 2-2h9"></path>
            </svg>
            <span>Copy</span>
            <span class="sr-only" data-copy-status aria-live="polite"></span>
          </button>
        </div>
      </section>

      <section class="section section-shell model-strip" id="model" aria-labelledby="model-title">
        <div class="section-heading">
          <p class="eyebrow">Reservation model</p>
          <h2 id="model-title">Same key, same port.</h2>
          <p>
            Reservations are keyed by directory and optional tag. Repeated calls return the same port.
          </p>
        </div>
      </section>

      <section class="section section--muted" id="features" aria-labelledby="features-title">
        <div class="section-shell">
          <div class="section-heading">
            <p class="eyebrow">What trop provides</p>
            <h2 id="features-title">Small guarantees for boring local ports</h2>
          </div>
          <div class="feature-grid">
            {siteConfig.landing.features.map((feature, index) => (
              <article class="feature-card">
                <span class="feature-card__index" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
                <p class="feature-card__eyebrow">{feature.eyebrow}</p>
                <h3>{feature.title}</h3>
                <p>{feature.body}</p>
                <a class="text-link" href={resolveHref(feature.href)}>Learn more</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-shell scope-strip" aria-labelledby="scope-title">
        <div class="scope-panel">
          <div>
            <p class="eyebrow">Scope</p>
            <h2 id="scope-title">Single-user coordination on one machine.</h2>
          </div>
          <div>
            <p class="scope-panel__label">Non-goals</p>
            <p>No system-wide enforcement. No multi-user broker. No container orchestration.</p>
          </div>
        </div>
      </section>

      <section class="section section-shell docs-preview" aria-labelledby="docs-title">
        <div class="section-heading">
          <p class="eyebrow">Documentation</p>
          <h2 id="docs-title">Keep detailed guidance in Starlight.</h2>
        </div>
        <div class="docs-grid">
          {siteConfig.docs.pages.map((page) => (
            <article class="doc-card">
              <h3>{page.title}</h3>
              <p>{page.description}</p>
              <a class="text-link" href={resolveHref(page.href)}>Open page</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section section--muted install-strip" id="install" aria-labelledby="install-title">
        <div class="section-shell install-strip__inner">
          <div class="section-heading">
            <p class="eyebrow">Install</p>
            <h2 id="install-title">Replace the fixed port.</h2>
            <p>Use <code>trop reserve</code> where a script expects a port.</p>
          </div>
          <div class="command-card command-card--compact" aria-label="Install commands">
            <pre class="command-card__body"><code>$ cargo install trop-cli
$ trop --version
$ PORT=$(trop reserve)</code></pre>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="section-shell site-footer__inner">
        <p>{siteConfig.project.title} / {siteConfig.project.category}</p>
        <nav aria-label="Footer">
          {siteConfig.landing.footerLinks.map((link) => (
            <a href={resolveHref(link.href)} target={externalTarget(link.href)} rel={externalRel(link.href)}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </footer>

    <script>
      import "../scripts/landing.ts";
    </script>
  </body>
</html>
